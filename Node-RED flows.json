    {
        "id": "d15ab36d8baf04bc",
        "type": "function",
        "z": "8b43cc276c50540b",
        "name": "Robot Runtime",
        "func": "let sec = parseInt(msg.payload);\nif (isNaN(sec)) sec = 0;\n\nlet hours = Math.floor(sec / 3600);\nlet minutes = Math.floor((sec % 3600) / 60);\nlet seconds = sec % 60;\n\nlet h = hours.toString().padStart(2, '0');\nlet m = minutes.toString().padStart(2, '0');\nlet s = seconds.toString().padStart(2, '0');\n\nmsg.payload = `Active for ${h}:${m}:${s}`;\nmsg.color = \"#2196F3\"; // 蓝色\n\nreturn msg;\n",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
