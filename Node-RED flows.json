        "name": "Tilt Status",
        "order": 3,
        "width": 6,
        "height": 2,
        "format": "<div style=\"padding: 10px; text-align: center;\">\n    <div id=\"tiltStatus\" style=\"font-size: 22px; font-weight: bold; padding: 15px; border-radius: 10px; color:white;\">\n        {{msg.payload}}\n    </div>\n</div>\n\n<script>\n    (function(scope) {\n    scope.$watch('msg', function(msg) {\n        if (!msg) return;\n\n        let box = document.getElementById(\"tiltStatus\");\n\n        // ⭐ 用 payload 判断，不用 msg.color （不会丢失）\n        if (msg.payload === \"⚠️ Robot Tilted!\") {\n            box.style.backgroundColor = \"red\";\n        } else {\n            box.style.backgroundColor = \"green\";\n        }\n    });\n})(scope);\n</script>",
