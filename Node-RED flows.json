        "height": 2,
        "format": "<div style=\"padding: 10px; text-align: center;\">\n    <div id=\"cliffStatus\" style=\"font-size: 22px; font-weight: bold; padding: 15px; border-radius: 10px;\">\n        {{payload}}\n    </div>\n</div>\n\n<script>\n    (function(scope) {\n    scope.$watch('msg', function(msg) {\n        if (!msg) return;\n\n        let box = document.getElementById(\"cliffStatus\");\n\n        if (msg.payload === \"⚠️ Cliff Detected!\") {\n            box.style.backgroundColor = \"red\";\n            box.style.color = \"white\";\n        } else {\n            box.style.backgroundColor = \"green\";\n            box.style.color = \"white\";\n        }\n    });\n})(scope);\n</script>",
