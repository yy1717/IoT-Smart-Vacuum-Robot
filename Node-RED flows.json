        "z": "8b43cc276c50540b",
        "name": "tiltStatus",
        "func": "// Debug for TILT (not cliff)\nlet y = String(msg.payload).trim();\n\nnode.warn(\"Received Tilt Value: \" + y);\n\nif (y === \"1\" || y.toLowerCase() === \"true\" || y === \"HIGH\"){\n    msg.payload = \"⚠️ Robot Tilted!\";\n    msg.color = \"red\";\n} else {\n    msg.payload = \"Upright\";\n    msg.color = \"green\";\n}\n\nreturn msg;\n",
