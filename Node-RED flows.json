    {
        "id": "dd1e6bdc41439e39",
        "type": "function",
        "z": "8b43cc276c50540b",
        "name": "Cliff Status",
        "func": "// Convert all values to string\nlet v = String(msg.payload).trim();\n\n// Debug check\nnode.warn(\"Received Cliff Value: \" + v);\n\n// Danger Conditions\nif (v === \"1\" || v.toLowerCase() === \"true\" || v === \"HIGH\") {\n    msg.payload = \"⚠️ Cliff Detected!\";\n    msg.color = \"red\";\n} else {\n    msg.payload = \"Safe\";\n    msg.color = \"green\";\n}\n\nreturn msg;\n",
