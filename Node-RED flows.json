    {
        "id": "f933ee810ee49b78",
        "type": "function",
        "z": "8b43cc276c50540b",
        "name": "Robot State",
        "func": "let s = String(msg.payload || \"\").trim();\n\n// 如果 payload 是空的，直接 return，不要更新 UI\nif (s === \"\") return null;\n\n// Debug\nnode.warn(\"Robot state raw: \" + s);\n\nswitch (s) {\n    case \"FORWARD\":\n        msg.payload = \"Moving Forward\";\n        msg.color = \"#4caf50\";\n        break;\n\n    case \"REVERSING\":\n        msg.payload = \"Reversing\";\n        msg.color = \"#ff9800\";\n        break;\n\n    case \"TURNING\":\n        msg.payload = \"Turning\";\n        msg.color = \"#ffb74d\";\n        break;\n\n    case \"STOP_CLIFF\":\n        msg.payload = \"Stopped (Cliff Detected)\";\n        msg.color = \"#f44336\";\n        break;\n\n    case \"STOP_TILT\":\n        msg.payload = \"Stopped (Tilt Detected)\";\n        msg.color = \"#e53935\";\n        break;\n\n    case \"STOP_EMERGENCY\":\n        msg.payload = \"Emergency Stop\";\n        msg.color = \"#d32f2f\";\n        break;\n\n    default:\n        return null;\n}\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
